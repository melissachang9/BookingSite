{
  "name": "booking-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:dashboard": "npm --workspace @booking/dashboard run dev",
    "dev:storefront": "npm --workspace @booking/storefront run dev",
    "build:dashboard": "npm --workspace @booking/dashboard run build",
    "build:storefront": "npm --workspace @booking/storefront run build",
    "typecheck:dashboard": "npm --workspace @booking/dashboard run typecheck",
    "typecheck:storefront": "npm --workspace @booking/storefront run typecheck",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  }
}